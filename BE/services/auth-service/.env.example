AUTH_APP_PORT=8000

AUTH_DATABASE_URL=jdbc:mysql://localhost:3306/auth_service?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
AUTH_DATABASE_USERNAME=root
AUTH_DATABASE_PASSWORD=
AUTH_JPA_DDL_AUTO=update
AUTH_JPA_SHOW_SQL=false

JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes-long
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=30

OTP_EXPIRATION_MINUTES=10
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=15

GOOGLE_CLIENT_ID=

MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCK_DURATION_MINUTES=15

AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_LOGIN=10
AUTH_RATE_LIMIT_RESEND_OTP=3
AUTH_RATE_LIMIT_VERIFY_EMAIL=10
AUTH_RATE_LIMIT_FORGOT_PASSWORD=3
AUTH_RATE_LIMIT_RESET_PASSWORD=10

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

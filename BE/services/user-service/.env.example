APP_NAME=user-service
APP_ENV=local
APP_PORT=8001

DATABASE_URL=jdbc:mysql://localhost:3306/user_service?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DATABASE_USERNAME=root
DATABASE_PASSWORD=
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
APP_SEED_ENABLED=true

# Docker Compose helpers
USER_SERVICE_PORT=8001
USER_MYSQL_PORT=3308
USER_MYSQL_DATABASE=user_service
USER_MYSQL_ROOT_PASSWORD=root
USER_JPA_DDL_AUTO=update
USER_JPA_SHOW_SQL=false

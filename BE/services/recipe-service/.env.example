APP_NAME=recipe-service
APP_ENV=local
APP_PORT=8002

DATABASE_URL=jdbc:mysql://localhost:3306/recipe_service?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DATABASE_USERNAME=root
DATABASE_PASSWORD=root
JPA_SHOW_SQL=false

# Docker Compose helpers
RECIPE_SERVICE_PORT=8002
RECIPE_MYSQL_PORT=3309
RECIPE_MYSQL_DATABASE=recipe_service
RECIPE_MYSQL_ROOT_PASSWORD=root
RECIPE_JPA_SHOW_SQL=false
APP_SEED_DATA_ENABLED=true
APP_CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=mss301/recipes
